      "25": {"path": "duration", "type": "direct"},
      "26": {"path": "_creator_other_projects", "type": "count_query"}
    },
    "factor_108": {
      "2": {"path": "parent_category"},
      "3": {"path": "category_name"},
      "4": {"path": "country.code"},
      "26": {"path": "rewards[0].amount"},
      "27": {"path": "rewards[*].amount", "type": "max"},
      "29": {"path": "rewards", "type": "length"},
      "30": {"path": "rewards[*] 'Super Early Bird' regex"},
      "31": {"path": "rewards[*] 'Early Bird' regex"},
      "32": {"path": "rewards[*] 'Bundle|Pack' regex"},
      "54": {"path": "story_images", "type": "length"},
      "65": {"path": "faqs_count"},
      "75": {"path": "_creator_query"},
      "92": {"path": "launched_at -> weekday"},
      "94": {"path": "duration"},
      "95": {"path": "launched_at -> season"},
      "96": {"path": "_category_trend_from_trend_data_json"},
      "99": {"path": "rewards[*].estimated_delivery"},
      "101": {"path": "rewards[*].shipping_summary -> free/paid"},
      "102": {"path": "parent_category + _success_rate_of_category"},
      "103": {"path": "is_project_we_love"},
      "104": {"path": "_creator_other_projects_count"},
      "108": {"path": "goal.amount / category_median_goal"}
    }
  },
  "scoring_weights": {
    "auto_weight": 0.4,
    "manual_weight": 0.6,
    "ml_weight": 0.3,
    "rule_weight": 0.7,
    "note": "최종 = rule_based*0.7 + ml_xgboost*0.3"
